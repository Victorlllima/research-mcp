# Reddit (OAuth2 app - script type)
# https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# YouTube Data API v3
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Product Hunt (Developer Token)
# https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_TOKEN=

# GitHub (optional, increases rate limit)
GITHUB_TOKEN=
